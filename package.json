{
  "name": "companion",
  "version": "2.4.0",
  "description": "Data-driven AI companion backend — archive-based persona modeling with RAG memory retrieval",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:init": "node src/db-init.js",
    "key:split": "node scripts/key-shares.js split",
    "key:combine": "node scripts/key-shares.js combine",
    "test": "node --test src/lib/*.test.js",
    "lint": "find src -name '*.js' -exec node --check {} +",
    "test:integration": "node --test src/integration.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.12.0"
  },
  "license": "MIT"
}
